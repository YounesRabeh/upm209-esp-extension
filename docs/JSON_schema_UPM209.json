{
  "schemaID": "schemaUNICAM",
  "title": "UNICAM UPM209 Measurement Payload",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaID": {
      "type": "string",
      "const": "schemaUNICAM",
      "description": "Schema identifier"
    },
    "companyID": {
      "type": "string",
      "const": "UNICAM",
      "description": "Company identifier"
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp"
    },
    "device_id": {
      "type": "string",
      "minLength": 1,
      "description": "Device serial number or identifier"
    },
    "firmware_version": {
      "type": "string",
      "minLength": 1,
      "description": "Firmware version running on the device"
    },
    "device_type": {
      "type": "string",
      "minLength": 1,
      "description": "Device type"
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "num_reg": {
            "type": "integer",
            "minimum": 0,
            "description": "Register number"
          },
          "avg": {
            "type": "number",
            "description": "Avg measured value"
          },
          "word": {
            "type": "integer",
            "minimum": 1,
            "description": "Natural dimension of data"
          },
          "min": {
            "type": "number",
            "description": "Minimum measured value"
          },
          "max": {
            "type": "number",
            "description": "Maximum measured value"
          },
          "unit": {
            "type": "string",
            "minLength": 1,
            "description": "Measurement unit"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Measurement description"
          }
        },
        "required": [
          "num_reg",
          "avg",
          "word",
          "min",
          "max",
          "unit",
          "description"
        ]
      }
    }
  },
  "required": [
    "schemaID",
    "companyID",
    "timestamp",
    "device_id",
    "firmware_version",
    "device_type",
    "measurements"
  ]
}
