menu "Storage Configuration"

config MEMORY_LITTLEFS_MOUNT_POINT
    string "LittleFS mount point"
    default "/lfs"
    help
      Base mount point used by the storage queue.

config MEMORY_LITTLEFS_PARTITION_LABEL
    string "LittleFS partition label"
    default "storage"
    help
      Partition label used by esp_vfs_littlefs_register().
      Leave empty to mount the first LittleFS partition found.

config MEMORY_SAMPLE_QUEUE_BYTES
    int "Queue capacity in bytes"
    default 262144
    range 4096 4194304
    help
      Maximum number of bytes reserved to store Modbus samples.

config MEMORY_MAX_REGISTERS
    int "Maximum registers per Modbus sample"
    default 160
    range 1 512
    help
      Upper bound for one sample payload, used as safety guard.

menuconfig MEMORY_MANAGER_ENABLE
    bool "Memory Manager"
    default n

if MEMORY_MANAGER_ENABLE

config MEMORY_MANAGER_PERIOD_MS
    int "Memory monitor period (ms)"
    default 5000
    range 500 60000

config MEMORY_MANAGER_TASK_STACK_SIZE
    int "Memory manager task stack size"
    default 3072
    range 2048 16384

config MEMORY_MANAGER_TASK_PRIORITY
    int "Memory manager task priority"
    default 4
    range 1 24

endif

choice MEMORY_OVERFLOW_POLICY
    prompt "Overflow policy"
    default MEMORY_OVERFLOW_OVERWRITE_OLDEST
    help
      Behavior when the queue is full.

config MEMORY_OVERFLOW_OVERWRITE_OLDEST
    bool "Overwrite oldest sample (circular queue)"

config MEMORY_OVERFLOW_REJECT_NEWEST
    bool "Reject newest sample when full"

endchoice

endmenu
